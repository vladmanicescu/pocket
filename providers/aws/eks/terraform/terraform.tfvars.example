# Copy to terraform.tfvars and adjust.

aws_region  = "eu-central-1"
aws_profile = "default"

project_name  = "pocket"
cluster_name  = "pocket-eks"
cluster_version = "1.31"

vpc_cidr       = "10.40.0.0/16"
az_count       = 2
single_nat_gateway = true

cluster_endpoint_public_access  = true
cluster_endpoint_private_access = true

node_instance_types = ["t3.medium"]
node_desired_size   = 2
node_min_size       = 1
node_max_size       = 4
node_disk_size      = 50

# Vault (KMS auto-unseal + Helm) — optional overrides (also driven by platform.yaml / pocket)
# vault_enabled           = true
# vault_replicas          = 1
# vault_data_storage_size = "10Gi"
